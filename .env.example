# ── Supabase (client-side, shipped to browser via Vite) ──────────────────────
# Your Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (Settings → API → anon / public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-side only, NEVER expose to browser) ─────────────────────
# Supabase service role key (Settings → API → service_role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Paystack ──────────────────────────────────────────────────────────────────
# Public key is safe to expose to the browser (used by Paystack.js)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret key — server-side only, never expose to browser
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# ── NOWPayments (crypto payments) ────────────────────────────────────────────
# API key — server-side only
NOWPAYMENTS_API_KEY=your-nowpayments-api-key-here

# ── Google OAuth (optional — handled through Supabase OAuth config) ───────────
# Not needed here: configure Google OAuth in Supabase Dashboard → Auth → Providers → Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used for redirect URLs in payment callbacks
# VITE_SITE_URL=https://your-app.replit.app
